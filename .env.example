# Airborne Aviation Academy - Environment Configuration Template
# Copy this file to .env.local and populate the values.

# 1. Supabase CRM Database Integration
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# 2. Omnichannel Communication Webhooks (Optional)
# Webhook to n8n triggers the 21-day WhatsApp nurture sequence
N8N_WHATSAPP_WEBHOOK=https://n8n.yourdomain.com/webhook/whatsapp-lead

# Webhook to Bland.ai / Vapi initiates outbound voice qualification calls within 120 seconds
VOICE_AI_WEBHOOK=https://api.vapi.ai/webhooks/outbound-call
VOICE_AI_TOKEN=vapi_token_here
