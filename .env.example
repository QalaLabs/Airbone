# ─── Airborne Aviation Academy — Marketing Site Environment Template ──────────
# Copy to .env.local for local dev. Set all REQUIRED vars in Vercel before deploy.
# Never commit real secrets.

# ─── Admin Backend (REQUIRED) ────────────────────────────────────────────────
# URL of the deployed admin Next.js app (no trailing slash)
ADMIN_API_URL="https://admin.airborneacademy.in"

# Shared secret for admin public API — must match admin's PUBLIC_INTAKE_KEY
PUBLIC_INTAKE_KEY="replace-with-same-value-as-admin-PUBLIC_INTAKE_KEY"

# ─── Org Identity (OPTIONAL — has safe default) ───────────────────────────────
# Org slug for public data queries (default: airborne-aviation)
PUBLIC_ORG_SLUG="airborne-aviation"

# ─── Omnichannel Communication (OPTIONAL) ────────────────────────────────────
# n8n webhook — triggers WhatsApp nurture sequence on lead capture
N8N_WHATSAPP_WEBHOOK=""

# Vapi / Bland.ai — outbound voice qualification call within 120 s of lead submit
VOICE_AI_WEBHOOK=""
VOICE_AI_TOKEN=""

# ─── CRM Push (OPTIONAL — server-side only) ───────────────────────────────────
# Groweon CRM capture endpoint for lead forwarding
CRM_ENDPOINT=""
CRM_COMPANY="Airborne Aviation"
CRM_SOURCE="Airborne Website"

# ─── Legacy / Supabase (OPTIONAL — currently unused in code, safe to omit) ───
# SUPABASE_URL=""
# SUPABASE_ANON_KEY=""

# ─── App ─────────────────────────────────────────────────────────────────────
NODE_ENV="production"
