  reviewer  User?        @relation("DocumentReviewer", fields: [reviewedBy], references: [id], onDelete: SetNull)

  @@index([orgId, status])
  @@index([studentId])
  @@index([admissionId])
  @@index([orgId, documentType])
  @@map("documents")
}

// ─── PAYMENT TRANSACTIONS ─────────────────────────────────────────────────────

enum PaymentMethod {
  CASH
  BANK_TRANSFER
  UPI
  CARD
  CHEQUE
  DD
  ONLINE
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
  PARTIALLY_REFUNDED
}

model PaymentTransaction {
  id              String        @id @default(uuid()) @db.Uuid
  orgId           String        @db.Uuid
  campusId        String?       @db.Uuid
  admissionId     String        @db.Uuid
  studentId       String?       @db.Uuid
  amount          Decimal       @db.Decimal(10, 2)
  currency        String        @default("INR") @db.VarChar(3)
  method          PaymentMethod
  status          PaymentStatus @default(PENDING)
  referenceNo     String?       @db.VarChar(255)
  receiptNo       String?       @db.VarChar(100)
  feeType         String?       @db.VarChar(100)
  description     String?       @db.Text
  paidAt          DateTime?
  gateway         String?       @db.VarChar(100)
  gatewayTxnId    String?       @db.VarChar(255)
  gatewayResponse Json?
  notes           String?       @db.Text
  collectedBy     String?       @db.Uuid
  metadata        Json          @default("{}")
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  org       Organization @relation("OrgPayments", fields: [orgId], references: [id], onDelete: Cascade)
  campus    Campus?      @relation("CampusPayments", fields: [campusId], references: [id], onDelete: SetNull)
  admission Admission    @relation("AdmissionPayments", fields: [admissionId], references: [id])
  student   Student?     @relation("StudentPayments", fields: [studentId], references: [id], onDelete: SetNull)
  collector User?        @relation("PaymentCollector", fields: [collectedBy], references: [id], onDelete: SetNull)

  @@index([orgId, status])
  @@index([admissionId])
  @@index([studentId])
  @@index([orgId, paidAt(sort: Desc)])
  @@index([orgId, createdAt(sort: Desc)])
  @@map("payment_transactions")
}

