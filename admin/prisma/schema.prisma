  @@index([campusId])
  @@index([orgId, createdAt(sort: Desc)])
  @@map("students")
}

// ─── ADMISSIONS ──────────────────────────────────────────────────────────────

enum AdmissionStage {
  ENQUIRY
  DOCUMENT_COLLECTION
  VERIFICATION
  OFFER_LETTER
  FEE_PAYMENT
  ENROLLED
  DROPPED
  CANCELLED
}

model Admission {
  id             String         @id @default(uuid()) @db.Uuid
  orgId          String         @db.Uuid
  campusId       String?        @db.Uuid
  studentId      String?        @db.Uuid
  leadId         String         @db.Uuid
  applicationNo  String         @db.VarChar(50)
  stage          AdmissionStage @default(ENQUIRY)
  courseName     String?        @db.VarChar(255)
  batchName      String?        @db.VarChar(255)
  batchStartDate DateTime?
  feeAmount      Decimal?       @db.Decimal(10, 2)
  feeDiscount    Decimal        @default(0) @db.Decimal(10, 2)
  feeFinal       Decimal?       @db.Decimal(10, 2)
  feePaid        Decimal        @default(0) @db.Decimal(10, 2)
  feeBalance     Decimal        @default(0) @db.Decimal(10, 2)
  counselorId    String?        @db.Uuid
  stageChangedAt DateTime?
  stageChangedBy String?        @db.Uuid
  notes          String?        @db.Text
  metadata       Json           @default("{}")
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  org          Organization         @relation("OrgAdmissions", fields: [orgId], references: [id], onDelete: Cascade)
  campus       Campus?              @relation("CampusAdmissions", fields: [campusId], references: [id], onDelete: SetNull)
  student      Student?             @relation(fields: [studentId], references: [id], onDelete: SetNull)
  lead         Lead                 @relation("LeadAdmissions", fields: [leadId], references: [id])
  counselor    User?                @relation("AdmissionCounselor", fields: [counselorId], references: [id], onDelete: SetNull)
  stageChanger User?                @relation("AdmissionStageChanger", fields: [stageChangedBy], references: [id], onDelete: SetNull)
  stageLogs    AdmissionStageLog[]
  documents    Document[]           @relation("AdmissionDocuments")
  payments     PaymentTransaction[] @relation("AdmissionPayments")

  @@unique([orgId, applicationNo])
  @@index([orgId, stage])
  @@index([studentId])
  @@index([leadId])
  @@index([counselorId])
  @@index([orgId, createdAt(sort: Desc)])
  @@map("admissions")
}

model AdmissionStageLog {
  id          String          @id @default(uuid()) @db.Uuid
  orgId       String          @db.Uuid
  admissionId String          @db.Uuid
  fromStage   AdmissionStage?
  toStage     AdmissionStage
  notes       String?         @db.Text
  changedBy   String?         @db.Uuid
  changedAt   DateTime        @default(now())

  admission Admission @relation(fields: [admissionId], references: [id], onDelete: Cascade)
  actor     User?     @relation("StageLogActor", fields: [changedBy], references: [id], onDelete: SetNull)

  @@index([admissionId, changedAt(sort: Desc)])
  @@index([orgId])
  @@map("admission_stage_logs")
}

// ─── DOCUMENTS ────────────────────────────────────────────────────────────────

enum DocumentType {
  AADHAR_CARD
  PAN_CARD
  PASSPORT
  PHOTO
  CLASS_10_MARKSHEET
  CLASS_12_MARKSHEET
  MEDICAL_CERTIFICATE
  BIRTH_CERTIFICATE
  BANK_STATEMENT
  OTHER
}

enum DocumentStatus {
  PENDING
  UPLOADED
  UNDER_REVIEW
  APPROVED
  REJECTED
}

model Document {
  id              String         @id @default(uuid()) @db.Uuid
  orgId           String         @db.Uuid
  studentId       String?        @db.Uuid
  admissionId     String?        @db.Uuid
  uploadedBy      String?        @db.Uuid
  reviewedBy      String?        @db.Uuid
  documentType    DocumentType
  name            String         @db.VarChar(255)
  fileUrl         String         @db.Text
  fileKey         String         @db.VarChar(500)
  fileMimeType    String?        @db.VarChar(100)
  fileSizeBytes   Int?
  status          DocumentStatus @default(UPLOADED)
  reviewedAt      DateTime?
  rejectionReason String?        @db.Text
