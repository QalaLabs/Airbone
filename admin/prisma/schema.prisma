// ============================================================
// AIRBORNE AVIATION ACADEMY — PRISMA SCHEMA
// Engine: PostgreSQL 15+  |  ORM: Prisma 6
// ============================================================

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters", "fullTextSearchPostgres"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── ENUMS ──────────────────────────────────────────────────────────────────

enum UserRole {
  SUPER_ADMIN
  ADMIN
  MARKETING_MANAGER
  CONTENT_MANAGER
  ADMISSIONS_COUNSELOR
  PLACEMENT_MANAGER
  SUPPORT_STAFF
  // SMS / LMS portal roles (additive — do not remove staff roles)
  TEACHER
  STUDENT
}

enum LeadStatus {
  NEW
  CONTACTED
  INTERESTED
  FOLLOW_UP
  COUNSELED
  APPLICATION_SUBMITTED
  CONVERTED
  LOST
}

enum LeadSource {
  HOMEPAGE_CTA
  COURSE_PAGE
  CONTACT_FORM
  CALLBACK_REQUEST
  BROCHURE_DOWNLOAD
  GOOGLE_ADS
  FACEBOOK_ADS
  ORGANIC
  REFERRAL
  WHATSAPP
  DIRECT
}

enum ActivityType {
  CALL
  EMAIL
  WHATSAPP
  SMS
  NOTE
  MEETING
  TASK
  STATUS_CHANGE
  ASSIGNMENT
  SYSTEM
}

enum NotificationChannel {
  EMAIL
  SMS
  WHATSAPP
  IN_APP
}

enum NotificationEvent {
  NEW_LEAD
  LEAD_ASSIGNED
  LEAD_STATUS_CHANGED
  ADMISSION_STAGE_CHANGED
  JOB_PUBLISHED
  TESTIMONIAL_SUBMITTED
  PAYMENT_RECEIVED
  PLACEMENT_ADDED
  ENQUIRY_RECEIVED
  USER_INVITED
  TASK_DUE
  WORKFLOW_TRIGGERED
}

enum WorkflowTrigger {
  LEAD_CREATED
  LEAD_STATUS_CHANGED
  LEAD_ASSIGNED
  ADMISSION_STAGE_CHANGED
  PAYMENT_RECEIVED
  FORM_SUBMITTED
  SCHEDULED
}

enum OrgPlan {
  STARTER
  PROFESSIONAL
  ENTERPRISE
}

enum ContentStatus {
  DRAFT
  PUBLISHED
  SCHEDULED
  ARCHIVED
}

enum ResourceType {
  PDF
  VIDEO
  LINK
  IMAGE
  DOCUMENT
  AUDIO
  OTHER
}

enum JobStatus {
  DRAFT
  PUBLISHED
  CLOSED
  ARCHIVED
}

enum JobApplicationStatus {
  SUBMITTED
  UNDER_REVIEW
  SHORTLISTED
  INTERVIEW_SCHEDULED
  SELECTED
  REJECTED
  WITHDRAWN
}

enum PlacementStatus {
  PENDING
  CONFIRMED
  CANCELLED
}

enum TestimonialStatus {
  PENDING
  APPROVED
  REJECTED
}

// ─── ORGANIZATIONS (Multi-tenant root) ──────────────────────────────────────

model Organization {
  id             String    @id @default(uuid()) @db.Uuid
  name           String    @db.VarChar(255)
  slug           String    @unique @db.VarChar(100)
  domain         String?   @db.VarChar(255)
  plan           OrgPlan   @default(STARTER)
  planExpiresAt  DateTime?
  logoUrl        String?
  settings       Json      @default("{}")
  featureFlags   Json      @default("{}")
  parentOrgId    String?   @db.Uuid
  isActive       Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  // Self-referential for HQ → campus hierarchy
  parentOrg      Organization?  @relation("OrgHierarchy", fields: [parentOrgId], references: [id])
  childOrgs      Organization[] @relation("OrgHierarchy")

  // Relations
  users          User[]
  campuses       Campus[]
  leads          Lead[]
  students       Student[]            @relation("OrgStudents")
  admissions     Admission[]          @relation("OrgAdmissions")
  documents      Document[]           @relation("OrgDocuments")
  payments       PaymentTransaction[] @relation("OrgPayments")
  auditLogs      AuditLog[]
  eventLogs      EventLog[]
  activityFeed   ActivityFeedItem[]
  permissions    Permission[]
  workflows      Workflow[]
  featureFlagRows FeatureFlag[]
  notifTemplates NotificationTemplate[]
  mediaFolders   MediaFolder[]        @relation("OrgMediaFolders")
  mediaAssets    MediaAsset[]         @relation("OrgMediaAssets")
  contentBlocks  ContentBlock[]       @relation("OrgContentBlocks")
  pages          Page[]               @relation("OrgPages")
  courses        Course[]             @relation("OrgCourses")
  navMenus       NavMenu[]            @relation("OrgNavMenus")
  resources      Resource[]           @relation("OrgResources")
  jobs           Job[]                @relation("OrgJobs")
  jobApplications JobApplication[]    @relation("OrgJobApplications")
  placements     Placement[]          @relation("OrgPlacements")
  hiringPartners HiringPartner[]      @relation("OrgHiringPartners")
  testimonials   Testimonial[]        @relation("OrgTestimonials")

  // SMS / LMS (additive)
  lmsCourses           LmsCourse[]           @relation("OrgLmsCourses")
  lmsEnrollments       LmsEnrollment[]       @relation("OrgLmsEnrollments")
  lmsAttendanceSessions LmsAttendanceSession[] @relation("OrgLmsAttendanceSessions")
  lmsCertificates      LmsCertificate[]      @relation("OrgLmsCertificates")
  lmsChatRooms         LmsChatRoom[]         @relation("OrgLmsChatRooms")
  lmsNotifications     LmsNotification[]     @relation("OrgLmsNotifications")
  lmsAnnouncements     LmsAnnouncement[]     @relation("OrgLmsAnnouncements")

  @@index([slug])
  @@index([isActive])
  @@map("organizations")
}

// ─── CAMPUSES ───────────────────────────────────────────────────────────────

model Campus {
  id              String   @id @default(uuid()) @db.Uuid
  orgId           String   @db.Uuid
  name            String   @db.VarChar(255)
  code            String   @db.VarChar(20)
  city            String   @db.VarChar(100)
  state           String   @db.VarChar(100)
  country         String   @default("IN") @db.VarChar(2)
  address         String?
  phone           String?  @db.VarChar(20)
  email           String?  @db.VarChar(255)
  headCounselorId String?  @db.Uuid
  timezone        String   @default("Asia/Kolkata") @db.VarChar(50)
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  org             Organization         @relation(fields: [orgId], references: [id], onDelete: Cascade)
  headCounselor   User?                @relation("CampusHead", fields: [headCounselorId], references: [id], onDelete: SetNull)
  users           User[]               @relation("CampusUsers")
  leads           Lead[]
  students        Student[]            @relation("CampusStudents")
  admissions      Admission[]          @relation("CampusAdmissions")
  payments        PaymentTransaction[] @relation("CampusPayments")

  @@unique([orgId, code])
  @@index([orgId])
  @@index([isActive])
  @@map("campuses")
}

// ─── USERS ──────────────────────────────────────────────────────────────────

model User {
  id            String    @id @default(uuid()) @db.Uuid
  orgId         String    @db.Uuid
  campusId      String?   @db.Uuid
  name          String    @db.VarChar(255)
  email         String    @db.VarChar(255)
  phone         String?   @db.VarChar(20)
  passwordHash  String?
  role          UserRole  @default(SUPPORT_STAFF)
  avatarUrl     String?
  emailVerified DateTime?
  isActive      Boolean   @default(true)
  isMfaEnabled  Boolean   @default(false)
  mfaSecret     String?
  lastLoginAt   DateTime?
  lastLoginIp   String?   @db.VarChar(45)
  invitedBy     String?   @db.Uuid
  inviteToken   String?   @unique
  inviteExpiry  DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?

  org           Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  campus        Campus?      @relation("CampusUsers", fields: [campusId], references: [id], onDelete: SetNull)

  // Auth.js adapter relations
  accounts      Account[]
  sessions      Session[]

  // Business relations
  assignedLeads           Lead[]               @relation("LeadCounselor")
  createdLeads            Lead[]               @relation("LeadCreator")
  leadActivities          LeadActivity[]
  auditLogs               AuditLog[]
  activityFeed            ActivityFeedItem[]
  headOfCampuses          Campus[]             @relation("CampusHead")
  workflowRuns            WorkflowRun[]
  counseledAdmissions     Admission[]          @relation("AdmissionCounselor")
  stageChangedAdmissions  Admission[]          @relation("AdmissionStageChanger")
  stageLogActions         AdmissionStageLog[]  @relation("StageLogActor")
  uploadedDocuments       Document[]           @relation("DocumentUploader")
  reviewedDocuments       Document[]           @relation("DocumentReviewer")
  collectedPayments       PaymentTransaction[] @relation("PaymentCollector")
  mediaFolders            MediaFolder[]        @relation("MediaFolderCreator")
  uploadedMediaAssets     MediaAsset[]         @relation("MediaAssetUploader")
  createdBlocks           ContentBlock[]       @relation("ContentBlockCreator")
  createdPages            Page[]               @relation("PageCreator")
  publishedPages          Page[]               @relation("PagePublisher")
  pageVersions            PageVersion[]        @relation("PageVersionCreator")
  createdCourses          Course[]             @relation("CourseCreator")
  publishedCourses        Course[]             @relation("CoursePublisher")
  courseVersions          CourseVersion[]      @relation("CourseVersionCreator")
  createdNavMenus         NavMenu[]            @relation("NavMenuCreator")
  createdResources        Resource[]           @relation("ResourceCreator")
  createdJobs             Job[]                @relation("JobCreator")
  publishedJobs           Job[]                @relation("JobPublisher")
  reviewedApplications    JobApplication[]     @relation("ApplicationReviewer")
  createdPlacements       Placement[]          @relation("PlacementCreator")
  createdHiringPartners   HiringPartner[]      @relation("HiringPartnerCreator")
  reviewedTestimonials    Testimonial[]        @relation("TestimonialReviewer")

  // SMS / LMS portal (additive)
  studentProfile          Student?             @relation("StudentAuthUser")
  teachingCourses         LmsCourseTeacher[]   @relation("LmsCourseTeacher")
  lmsProgress             LmsStudentProgress[] @relation("LmsProgressStudent")
  lmsAssessments          LmsAssessment[]      @relation("LmsAssessmentStudent")
  lmsSentMessages         LmsMessage[]         @relation("LmsSentMessages")
  lmsNotifications        LmsNotification[]    @relation("LmsNotificationUser")
  issuedCertificates      LmsCertificate[]     @relation("LmsCertificateIssuer")
  markedAttendance        LmsAttendanceRecord[] @relation("LmsAttendanceMarker")
  lmsQuizAttempts         LmsQuizAttempt[]     @relation("LmsQuizAttemptUser")
  lmsAnnouncements        LmsAnnouncement[]    @relation("LmsAnnouncementCreator")

  @@unique([email, orgId])
  @@index([orgId, role])
  @@index([orgId, isActive])
  @@index([email])
  @@map("users")
}

// ─── AUTH.JS ADAPTER TABLES ─────────────────────────────────────────────────

model Account {
  id                String  @id @default(uuid()) @db.Uuid
  userId            String  @db.Uuid
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(uuid()) @db.Uuid
  sessionToken String   @unique
  userId       String   @db.Uuid
  expires      DateTime
  ipAddress    String?  @db.VarChar(45)
  userAgent    String?  @db.Text
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ─── PERMISSIONS (RBAC + ABAC) ──────────────────────────────────────────────

model Permission {
  id           String   @id @default(uuid()) @db.Uuid
  orgId        String   @db.Uuid
  role         UserRole
  resource     String   @db.VarChar(100)
  action       String   @db.VarChar(50)
  conditions   Json?
  campusScope  Boolean  @default(false)
  createdAt    DateTime @default(now())

  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([orgId, role, resource, action])
  @@index([orgId, role])
  @@map("permissions")
}

// ─── LEADS ──────────────────────────────────────────────────────────────────

model Lead {
  id             String     @id @default(uuid()) @db.Uuid
  orgId          String     @db.Uuid
  campusId       String?    @db.Uuid
  name           String     @db.VarChar(255)
  email          String?    @db.VarChar(255)
  phone          String     @db.VarChar(20)
  city           String?    @db.VarChar(100)
  state          String?    @db.VarChar(100)
  courseInterest String?    @db.VarChar(255)
  source         LeadSource @default(DIRECT)
  status         LeadStatus @default(NEW)
  assignedTo     String?    @db.Uuid
  createdBy      String?    @db.Uuid

  // UTM / attribution
  utmSource   String? @db.VarChar(255)
  utmMedium   String? @db.VarChar(255)
  utmCampaign String? @db.VarChar(255)
  utmTerm     String? @db.VarChar(255)
  utmContent  String? @db.VarChar(255)
  referrerUrl String? @db.Text
  landingPage String? @db.Text

  // Scoring
  score       Int     @default(0)
  tags        String[]
  customFields Json   @default("{}")

  // Dedup
  isDuplicate Boolean @default(false)
  duplicateOf String? @db.Uuid

  // Outcome
  convertedAt DateTime?
  lostReason  String?   @db.Text
  nextFollowUp DateTime?
  lastActivityAt DateTime?

  metadata    Json      @default("{}")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  // Relations
  org          Organization  @relation(fields: [orgId], references: [id], onDelete: Cascade)
  campus       Campus?       @relation(fields: [campusId], references: [id], onDelete: SetNull)
  counselor    User?         @relation("LeadCounselor", fields: [assignedTo], references: [id], onDelete: SetNull)
  creator      User?         @relation("LeadCreator", fields: [createdBy], references: [id], onDelete: SetNull)
  duplicateRef Lead?         @relation("LeadDuplicate", fields: [duplicateOf], references: [id], onDelete: SetNull)
  duplicates   Lead[]        @relation("LeadDuplicate")
  activities   LeadActivity[]
  scoreHistory LeadScoreHistory[]
  admissions   Admission[]   @relation("LeadAdmissions")
  student      Student?      @relation("LeadStudent")

  @@index([orgId, status])
  @@index([orgId, assignedTo, createdAt(sort: Desc)])
  @@index([orgId, createdAt(sort: Desc)])
  @@unique([orgId, phone])
  @@index([phone, orgId])
  @@index([email, orgId])
  @@index([orgId, score(sort: Desc)])
  @@map("leads")
}

// ─── LEAD ACTIVITIES ────────────────────────────────────────────────────────

model LeadActivity {
  id            String       @id @default(uuid()) @db.Uuid
  leadId        String       @db.Uuid
  orgId         String       @db.Uuid
  performedBy   String?      @db.Uuid
  activityType  ActivityType
  title         String?      @db.VarChar(500)
  notes         String?      @db.Text
  outcome       String?      @db.VarChar(255)
  nextAction    String?      @db.Text
  dueAt         DateTime?
  completedAt   DateTime?
  durationMins  Int?
  metadata      Json         @default("{}")
  createdAt     DateTime     @default(now())

  lead      Lead  @relation(fields: [leadId], references: [id], onDelete: Cascade)
  performer User? @relation(fields: [performedBy], references: [id], onDelete: SetNull)

  @@index([leadId, createdAt(sort: Desc)])
  @@index([performedBy])
  @@index([dueAt])
  @@index([orgId, dueAt])
  @@map("lead_activities")
}

// ─── LEAD SCORE HISTORY ─────────────────────────────────────────────────────

model LeadScoreHistory {
  id        String   @id @default(uuid()) @db.Uuid
  leadId    String   @db.Uuid
  orgId     String   @db.Uuid
  score     Int
  reason    String?  @db.VarChar(255)
  createdAt DateTime @default(now())

  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([leadId, createdAt(sort: Desc)])
  @@map("lead_score_history")
}

// ─── AUDIT LOGS (Append-only, hash-chained) ──────────────────────────────────

model AuditLog {
  id          BigInt   @id @default(autoincrement())
  orgId       String   @db.Uuid
  userId      String?  @db.Uuid
  sessionId   String?  @db.Uuid
  requestId   String?  @db.Uuid
  action      String   @db.VarChar(100)
  entityType  String   @db.VarChar(100)
  entityId    String?  @db.VarChar(255)
  oldValue    Json?
  newValue    Json?
  diff        Json?
  ipAddress   String?  @db.VarChar(45)
  userAgent   String?  @db.Text
  prevHash    String?  @db.VarChar(64)
  rowHash     String?  @db.VarChar(64)
  occurredAt  DateTime @default(now())

  org  Organization @relation(fields: [orgId], references: [id])
  user User?        @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([orgId, occurredAt(sort: Desc)])
  @@index([userId])
  @@index([entityType, entityId])
  @@map("audit_logs")
}

// ─── EVENT LOG (Immutable event stream) ──────────────────────────────────────

model EventLog {
  id          BigInt   @id @default(autoincrement())
  orgId       String   @db.Uuid
  eventName   String   @db.VarChar(255)
  actorId     String?  @db.Uuid
  actorType   String?  @db.VarChar(50)
  entityType  String?  @db.VarChar(100)
  entityId    String?  @db.VarChar(255)
  payload     Json     @default("{}")
  occurredAt  DateTime @default(now())

  org Organization @relation(fields: [orgId], references: [id])

  @@index([orgId, occurredAt(sort: Desc)])
  @@index([orgId, eventName])
  @@index([entityType, entityId])
  @@map("event_log")
}

// ─── ACTIVITY FEED ──────────────────────────────────────────────────────────

model ActivityFeedItem {
  id             String   @id @default(uuid()) @db.Uuid
  orgId          String   @db.Uuid
  actorId        String?  @db.Uuid
  verb           String   @db.VarChar(100)
  objectType     String   @db.VarChar(100)
  objectId       String   @db.VarChar(255)
  objectSnapshot Json
  targetId       String?  @db.VarChar(255)
  targetType     String?  @db.VarChar(100)
  context        Json     @default("{}")
  occurredAt     DateTime @default(now())

  org   Organization @relation(fields: [orgId], references: [id])
  actor User?        @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@index([orgId, occurredAt(sort: Desc)])
  @@index([actorId, occurredAt(sort: Desc)])
  @@index([objectType, objectId])
  @@map("activity_feed_items")
}

// ─── NOTIFICATION TEMPLATES ──────────────────────────────────────────────────

model NotificationTemplate {
  id        String              @id @default(uuid()) @db.Uuid
  orgId     String              @db.Uuid
  event     NotificationEvent
  channel   NotificationChannel
  name      String              @db.VarChar(255)
  subject   String?             @db.VarChar(500)
  body      String              @db.Text
  variables String[]
  isActive  Boolean             @default(true)
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt

  org  Organization      @relation(fields: [orgId], references: [id], onDelete: Cascade)
  logs NotificationLog[]

  @@unique([orgId, event, channel])
  @@map("notification_templates")
}

// ─── NOTIFICATION LOGS ──────────────────────────────────────────────────────

model NotificationLog {
  id          String              @id @default(uuid()) @db.Uuid
  orgId       String              @db.Uuid
  templateId  String?             @db.Uuid
  event       NotificationEvent?
  channel     NotificationChannel
  recipient   String              @db.VarChar(255)
  subject     String?             @db.Text
  body        String?             @db.Text
  status      String              @default("PENDING") @db.VarChar(30)
  errorMsg    String?             @db.Text
  externalId  String?             @db.VarChar(255)
  entityType  String?             @db.VarChar(100)
  entityId    String?             @db.VarChar(255)
  sentAt      DateTime?
  createdAt   DateTime            @default(now())

  template NotificationTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)

  @@index([orgId, status])
  @@index([orgId, createdAt(sort: Desc)])
  @@map("notification_logs")
}

// ─── WORKFLOWS ───────────────────────────────────────────────────────────────

model Workflow {
  id                 String          @id @default(uuid()) @db.Uuid
  orgId              String          @db.Uuid
  name               String          @db.VarChar(255)
  description        String?         @db.Text
  triggerEvent       WorkflowTrigger
  triggerConditions  Json            @default("{}")
  steps              Json            @default("[]")
  isActive           Boolean         @default(true)
  version            Int             @default(1)
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt

  org  Organization  @relation(fields: [orgId], references: [id], onDelete: Cascade)
  runs WorkflowRun[]

  @@index([orgId, isActive])
  @@map("workflows")
}

model WorkflowRun {
  id           String   @id @default(uuid()) @db.Uuid
  orgId        String   @db.Uuid
  workflowId   String   @db.Uuid
  entityType   String   @db.VarChar(100)
  entityId     String   @db.VarChar(255)
  triggeredBy  String?  @db.Uuid
  currentStep  Int      @default(0)
  status       String   @default("RUNNING") @db.VarChar(30)
  context      Json     @default("{}")
  error        String?  @db.Text
  startedAt    DateTime @default(now())
  completedAt  DateTime?

  workflow  Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  triggerer User?    @relation(fields: [triggeredBy], references: [id], onDelete: SetNull)

  @@index([workflowId])
  @@index([entityType, entityId])
  @@map("workflow_runs")
}

// ─── STUDENTS ────────────────────────────────────────────────────────────────

enum StudentStatus {
  ACTIVE
  GRADUATED
  DROPPED
  SUSPENDED
  ON_HOLD
}

model Student {
  id             String        @id @default(uuid()) @db.Uuid
  orgId          String        @db.Uuid
  campusId       String?       @db.Uuid
  leadId         String?       @unique @db.Uuid
  // Optional portal login link (SMS) — staff CRM Student stays intact without userId
  userId         String?       @unique @db.Uuid
  studentCode    String        @db.VarChar(50)
  firstName      String        @db.VarChar(100)
  lastName       String        @db.VarChar(100)
  email          String        @db.VarChar(255)
  phone          String        @db.VarChar(20)
  dateOfBirth    DateTime?
  gender         String?       @db.VarChar(20)
  nationality    String        @default("Indian") @db.VarChar(100)
  address        Json          @default("{}")
  guardianName   String?       @db.VarChar(255)
  guardianPhone  String?       @db.VarChar(20)
  guardianEmail  String?       @db.VarChar(255)
  medicalFitness Boolean       @default(false)
  class10Board   String?       @db.VarChar(100)
  class10Year    Int?
  class10Percent Float?
  class12Board   String?       @db.VarChar(100)
  class12Year    Int?
  class12Percent Float?
  class12Stream  String?       @db.VarChar(100)
  status         StudentStatus @default(ACTIVE)
  enrolledAt     DateTime?
  graduatedAt    DateTime?
  droppedAt      DateTime?
  customFields   Json          @default("{}")
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  deletedAt      DateTime?

  org        Organization         @relation("OrgStudents", fields: [orgId], references: [id], onDelete: Cascade)
  campus     Campus?              @relation("CampusStudents", fields: [campusId], references: [id], onDelete: SetNull)
  lead       Lead?                @relation("LeadStudent", fields: [leadId], references: [id], onDelete: SetNull)
  user       User?                @relation("StudentAuthUser", fields: [userId], references: [id], onDelete: SetNull)
  admissions Admission[]
  documents     Document[]           @relation("StudentDocuments")
  payments      PaymentTransaction[] @relation("StudentPayments")
  applications  JobApplication[]     @relation("StudentApplications")
  placements    Placement[]          @relation("StudentPlacements")
  testimonials  Testimonial[]        @relation("StudentTestimonials")

  // SMS / LMS
  lmsEnrollments       LmsEnrollment[]       @relation("StudentLmsEnrollments")
  lmsProgress          LmsStudentProgress[]  @relation("StudentLmsProgress")
  lmsAssessments       LmsAssessment[]       @relation("StudentLmsAssessments")
  lmsAttendanceRecords LmsAttendanceRecord[] @relation("StudentLmsAttendance")
  lmsCertificates      LmsCertificate[]      @relation("StudentLmsCertificates")
