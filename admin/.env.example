# ─── Database ───────────────────────────────────────────────────────────────
# Neon PostgreSQL (or local pg)
DATABASE_URL="postgresql://user:password@host:5432/airborne_admin?sslmode=require"
# Direct URL for Prisma migrations (bypasses connection pooler)
DIRECT_URL="postgresql://user:password@host:5432/airborne_admin?sslmode=require"

# ─── Auth.js (NextAuth v5) ───────────────────────────────────────────────────
# Generate: openssl rand -base64 32
AUTH_SECRET="your-auth-secret-here"
AUTH_URL="http://localhost:3001"

# ─── Inngest ────────────────────────────────────────────────────────────────
INNGEST_EVENT_KEY="local"
INNGEST_SIGNING_KEY="signkey-prod-..."

# ─── Cloudflare R2 ──────────────────────────────────────────────────────────
R2_ACCOUNT_ID="your-account-id"
R2_ACCESS_KEY_ID="your-access-key"
R2_SECRET_ACCESS_KEY="your-secret-key"
R2_BUCKET_NAME="airborne-media"
R2_BUCKET_DOCS="airborne-docs"
R2_PUBLIC_URL="https://media.airborneacademy.in"

# ─── Upstash Redis ──────────────────────────────────────────────────────────
UPSTASH_REDIS_REST_URL="https://..."
UPSTASH_REDIS_REST_TOKEN="..."

# ─── Resend (email) ─────────────────────────────────────────────────────────
RESEND_API_KEY="re_..."
RESEND_FROM_EMAIL="noreply@airborneacademy.in"

# ─── Twilio (SMS) ───────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID="AC..."
TWILIO_AUTH_TOKEN="..."
TWILIO_PHONE_NUMBER="+91..."

# ─── WATI (WhatsApp) ────────────────────────────────────────────────────────
WATI_API_URL="https://live-server-XXXX.wati.io"
WATI_API_TOKEN="..."

# ─── App ────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3001"
NEXT_PUBLIC_APP_NAME="Airborne OS"
NODE_ENV="development"
