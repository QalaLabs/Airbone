# ─── Airborne Admin OS — Environment Template ────────────────────────────────
# Copy to .env.local for local dev. Set all REQUIRED vars in Vercel before deploy.
# Never commit real secrets.

# ─── Database (REQUIRED) ─────────────────────────────────────────────────────
# Neon / Supabase PostgreSQL — use a connection-pooler URL for DATABASE_URL
DATABASE_URL="postgresql://user:password@pooler-host:5432/airborne_admin?sslmode=require&pgbouncer=true"
# Direct (non-pooled) URL for Prisma migrate deploy — bypasses PgBouncer
DIRECT_URL="postgresql://user:password@direct-host:5432/airborne_admin?sslmode=require"

# ─── Auth.js v5 (REQUIRED) ───────────────────────────────────────────────────
# Generate: openssl rand -base64 32
AUTH_SECRET="replace-with-openssl-rand-base64-32"
# Full URL of this admin app (no trailing slash)
AUTH_URL="https://admin.airborneacademy.in"

# ─── Public API (REQUIRED) ───────────────────────────────────────────────────
# Shared secret between marketing site and admin API — set the same value in both
PUBLIC_INTAKE_KEY="replace-with-a-random-secret-min-32-chars"
# Org slug used for public API queries (default: airborne-aviation)
PUBLIC_ORG_SLUG="airborne-aviation"

# ─── Cloudflare R2 Storage (REQUIRED for file uploads) ───────────────────────
# Missing in dev → mock presign URL returned (no crash).
# Missing in production → document uploads throw a clear error.
R2_ACCOUNT_ID="your-cf-account-id"
R2_ACCESS_KEY_ID="your-r2-access-key"
R2_SECRET_ACCESS_KEY="your-r2-secret-key"
R2_BUCKET_NAME="airborne-media"
R2_BUCKET_DOCS="airborne-docs"
R2_PUBLIC_URL="https://media.airborneacademy.in"

# ─── Inngest (REQUIRED in production) ────────────────────────────────────────
# Missing INNGEST_EVENT_KEY falls back to "local" (safe for dev/preview).
# Set real keys in Vercel Production — get them from app.inngest.com.
INNGEST_EVENT_KEY="local"
INNGEST_SIGNING_KEY="signkey-prod-replace-me"

# ─── Google Gemini AI (OPTIONAL) ─────────────────────────────────────────────
# Powers the LMS study assistant. Missing → stub response returned, no crash.
GEMINI_API_KEY=""

# ─── Twilio SMS (OPTIONAL — reserved for future SMS notifications) ────────────
# Not yet wired in code. Safe to leave blank; no runtime crash.
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_PHONE_NUMBER=""

# ─── WATI WhatsApp (OPTIONAL — reserved for future notifications) ─────────────
# Sprint 5 notification worker. Safe to leave blank; no runtime crash.
WATI_API_URL=""
WATI_API_TOKEN=""

# ─── Resend Email (OPTIONAL — reserved for future email notifications) ────────
RESEND_API_KEY=""
RESEND_FROM_EMAIL="noreply@airborneacademy.in"

# ─── Upstash Redis (OPTIONAL — reserved for rate-limiting / cache) ────────────
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# ─── CRM Integrations (OPTIONAL) ─────────────────────────────────────────────
NEXT_PUBLIC_FACEBOOK_APP_ID=""
NEXT_PUBLIC_GOOGLE_ADS_CONFIGURED="false"
NEXT_PUBLIC_FRAPPE_URL="http://localhost:8000"

# ─── App ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="https://admin.airborneacademy.in"
NEXT_PUBLIC_APP_NAME="Airborne OS"
NODE_ENV="production"
